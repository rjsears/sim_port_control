    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.3",
    "autoprefixer": "^10.4.17",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^9.21.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.12",
    "vitest": "^1.2.2",
    "@vitest/coverage-v8": "^1.2.2",
    "@vue/test-utils": "^2.4.4",
    "jsdom": "^24.0.0"
  }
