# =============================================================================
# SimPortControl Environment Configuration
# =============================================================================
# Copy this file to .env and update values before running

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=production
APP_NAME=SimPortControl
DOMAIN=simportcontrol.loft.aero
TIMEZONE=America/Chicago

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this

# Encryption key for storing switch credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_NAME=simportcontrol
DATABASE_USER=simportcontrol
DATABASE_PASSWORD=change-this-password
POSTGRES_CONTAINER=simportcontrol_db

# -----------------------------------------------------------------------------
# Docker Hub Settings
# -----------------------------------------------------------------------------
DOCKER_HUB_USERNAME=rjsears
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Container Names
# -----------------------------------------------------------------------------
APP_CONTAINER=simportcontrol_app
FRONTEND_CONTAINER=simportcontrol_frontend_init
NGINX_CONTAINER=simportcontrol_nginx
CERTBOT_CONTAINER=simportcontrol_certbot

# -----------------------------------------------------------------------------
# Default Admin User (created on first run)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# -----------------------------------------------------------------------------
# SSL/Certbot Settings
# -----------------------------------------------------------------------------
CERTBOT_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# Default Port Settings
# -----------------------------------------------------------------------------
DEFAULT_TIMEOUT_HOURS=4
DEFAULT_VLAN=30
